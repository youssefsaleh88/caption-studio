GEMINI_API_KEY=your_gemini_key
# Optional model fallback order (left -> right). Defaults:
# gemini-3-flash-preview,gemini-2.5-pro,gemini-2.5-flash,gemini-1.5-flash,gemini-2.5-flash-lite
# GEMINI_MODELS=gemini-3-flash-preview,gemini-2.5-flash,gemini-2.5-pro
# Optional fallback keys:
# GEMINI_API_KEYS=key_a,key_b,key_c
# GEMINI_API_KEY_1=key_a
# GEMINI_API_KEY_2=key_b
# Optional: absolute path to a .ttf used for FFmpeg burn-in (fontsdir); Docker image includes Noto Sans Arabic under /usr/share/fonts/
# CAPTION_FONT_FILE=

MAX_VIDEO_MB=200
PORT=8000
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=caption-studio-videos
R2_PUBLIC_BASE_URL=https://pub-your-bucket-id.r2.dev
R2_UPLOAD_URL_EXPIRES_SECONDS=900
